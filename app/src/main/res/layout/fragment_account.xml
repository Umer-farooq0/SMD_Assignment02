<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AccountFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Page title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="My Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="20dp" />

        <!-- Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_name"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Email -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_email"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_address"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Date of Birth -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_dob"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_dob"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Gender -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_gender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_gender"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Phone Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/account_phone"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="12dp" />

        <!-- Password (from strings.xml) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="2dp" />
        <TextView
            android:id="@+id/tv_account_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/password"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:padding="12dp"
            android:background="@color/card_bg"
            android:layout_marginBottom="24dp" />

        <!-- Logout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_account_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/logout"
            android:textColor="@color/white"
            app:backgroundTint="@color/black"
            app:cornerRadius="12dp" />

    </LinearLayout>

</ScrollView>